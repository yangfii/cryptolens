# ============================================================================
# CryptoLens — environment variables
# Copy to .env.local and fill in the values you need.
# ============================================================================

# ----- AI -------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----- Supabase (required for Trader Connect feature) -----------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Trader Connect -------------------------------------------------------
# 32-byte secret, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TRADER_SECRET_KEY=

# MetaApi.cloud token (free tier: https://metaapi.cloud) used to bridge MT4/MT5.
METAAPI_TOKEN=
# Region where your MetaApi accounts are provisioned.
# Common values: new-york, london, singapore.
METAAPI_REGION=new-york
